# ============================================
# IGT Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# ============================================

# Google Gemini API Keys (comma-separated for multiple keys)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEYS=

# Alibaba Qwen (DashScope) API Keys
# Get yours at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEYS=

# Deepseek API Keys
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEYS=

# Default LLM Provider (gemini, qwen, deepseek, or ollama)
IGT_LLM_PROVIDER=gemini

# Model overrides (optional — overrides models configured in igt_config.json)
IGT_GEMINI_FLASH_MODEL=            # e.g. gemini-2.5-flash
IGT_GEMINI_PRO_MODEL=              # e.g. gemini-2.5-pro
IGT_QWEN_FLASH_MODEL=              # e.g. qwen-turbo, qwen-plus
IGT_QWEN_PRO_MODEL=                # e.g. qwen-plus, qwen-max
IGT_DEEPSEEK_FLASH_MODEL=          # e.g. deepseek-chat
IGT_DEEPSEEK_PRO_MODEL=            # e.g. deepseek-reasoner

# Ollama model overrides (optional — defaults to the family-specific model in igt_config.json)
IGT_OLLAMA_FLASH_MODEL=            # e.g. phi4, gemma4:e4b
IGT_OLLAMA_PRO_MODEL=              # e.g. phi4, gemma4:e4b

# File paths (can be absolute or relative to project root)
IGT_DB_PATH=igt_data.db            # Primary SQLite database for grammar history
IGT_GRAMMAR_REF_DB_PATH=grammar_ref.db  # Grammar reference database
IGT_LOG_PATH=igt_db_error.log      # Logs background technical/DB errors
IGT_REVIEW_PATH=                   # Optional: human-readable Markdown log of all corrections
IGT_REPORT_PATH=                   # Folder for generated reports (Handbooks, Assessments)

# Vocabulary & Obsidian Vault (optional)
IGT_VAULT_DIR=                     # Root directory of your Obsidian vault (Practice history & Vocabulary)
IGT_VOCABULARY_FILE=               # Specific file for vocabulary (within Vault)
IGT_PRACTICE_FILE=                 # Specific file for practice logs (within Vault)
IGT_ASK_FILE=                      # Specific file for /ask consultation log (within Vault)
IGT_ASK_DIR=                       # Specific directory for /ask separate notes (within Vault)

# UI
IGT_THEME=auto                     # auto, light, dark, or any named theme

# Environment Variables for IGT behavior
GEMINI_SYSTEM_MD=false
GEMINI_TELEMETRY_ENABLED=false
IGT_PRE_FETCH_INSTEAD_OF_TOOLS=false # Set to true to bypass native tool calling and use fast pre-fetch injection for cloud models

# ── VPN / Network bypass (optional) ──────────────────────────────────────────
# IGT_LOCAL_ADDRESS forces outbound Qwen and Deepseek API calls to bind to a
# specific local network interface, routing them around a VPN or TUN adapter.
#
# When to set this:
#   You are behind a VPN that blocks or rate-limits these APIs, and you want
#   those requests to go through your physical NIC (Wi-Fi or Ethernet) instead.
#
# How to find your physical interface IP (macOS):
#   ipconfig getifaddr en0    # Wi-Fi
#   ipconfig getifaddr en1    # Ethernet
#
# Example:
#   IGT_LOCAL_ADDRESS=
#
# If you connect directly to the internet (no VPN), leave this empty.
IGT_LOCAL_ADDRESS=

