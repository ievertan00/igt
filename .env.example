# ============================================
# IGT Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# ============================================

# Google Gemini API Keys (comma-separated for multiple keys)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEYS=

# Alibaba Qwen (DashScope) API Keys
# Get yours at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEYS=

# Deepseek API Keys
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEYS=

# Default LLM Provider (gemini, qwen, or deepseek)
IGT_LLM_PROVIDER=gemini

# File paths (can be absolute or relative to project root)
IGT_REVIEW_PATH=
IGT_REPORT_PATH=

# Environment Variables for IGT behavior
GEMINI_SYSTEM_MD=false
GEMINI_TELEMETRY_ENABLED=false
NO_COLOR=1
